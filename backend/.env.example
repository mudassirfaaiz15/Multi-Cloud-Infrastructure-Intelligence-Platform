# ConsoleSensei Cloud Ops - Backend Environment Configuration
# Copy this file to .env and update with your actual values
#
# SECURITY WARNING: Never commit .env with real secrets to version control
# Use environment variable management:
# - AWS Parameter Store (for AWS deployments)
# - Railway Secrets (for Railway deployments)
# - Vercel Environment Variables (for serverless)
# - HashiCorp Vault (for self-hosted)

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
FLASK_ENV=development  # development | testing | production
FLASK_DEBUG=True
PORT=5000

# ============================================================================
# SECURITY & JWT
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ============================================================================
# CORS & API SECURITY
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# AWS CONFIGURATION
# ============================================================================
# IMPORTANT: In production, use IAM Roles instead of credentials!
# Only use credentials for development/testing
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ============================================================================
# ANTHROPIC CLAUDE API
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-v0-...

# ============================================================================
# SUPABASE (User Management & RBAC Database)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGc...
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/consolesensei_dev

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
SENTRY_DSN=  # Optional: https://key@sentry.io/project-id

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_AI_FEATURES=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_AUDIT_LOGGING=true

# ============================================================================
# AWS CONFIGURATION
# ============================================================================
# Note: AWS credentials should NOT be stored in .env file
# Pass them via API requests instead for security
# AWS_ACCESS_KEY_ID=your-access-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-key-here
# AWS_DEFAULT_REGION=us-east-1

# ============================================================================
# API AUTHENTICATION
# ============================================================================
# Secret key for JWT token signing - change this in production!
SECRET_KEY=your-super-secret-key-change-in-production-12345

# Valid API keys (comma-separated)
VALID_API_KEYS=dev-api-key-1,dev-api-key-2

# JWT token expiration in hours
JWT_EXPIRATION_HOURS=24

# ============================================================================
# AWS API CONFIGURATION
# ============================================================================
# Maximum concurrent workers for multi-region scanning
AWS_MAX_WORKERS=5

# AWS API request timeout in seconds
AWS_REQUEST_TIMEOUT=30

# Maximum retries for failed AWS API calls
AWS_MAX_RETRIES=3

# ============================================================================
# SCANNING CONFIGURATION
# ============================================================================
# Cache TTL for scan results in hours
SCAN_CACHE_TTL_HOURS=1

# Maximum scan operation timeout in seconds
SCAN_TIMEOUT_SECONDS=600

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=aws_resource_tracker.log

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed origins for CORS (comma-separated)
# Use * for development, restrict in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://example.com

# ============================================================================
# DATABASE (Optional - for caching scan results)
# ============================================================================
# DATABASE_URL=sqlite:///aws_resources.db
# or
# DATABASE_URL=postgresql://user:password@localhost/aws_tracker

# ============================================================================
# MONITORING & METRICS (Optional)
# ============================================================================
# Sentry error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# DataDog API key for metrics
# DATADOG_API_KEY=your-datadog-key

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
# Whether running in debug mode
DEBUG=True

# Application environment
ENVIRONMENT=development

# ============================================================================
# NOTES
# ============================================================================
# 1. NEVER commit the .env file with real credentials to version control
# 2. Use environment variables or secrets management (AWS Secrets Manager, etc.)
# 3. In production, set FLASK_ENV=production and DEBUG=False
# 4. Change SECRET_KEY to a strong random value in production
# 5. Use HTTPS in production
# 6. Restrict CORS_ORIGINS to specific domains
# 7. Implement rate limiting for API endpoints
