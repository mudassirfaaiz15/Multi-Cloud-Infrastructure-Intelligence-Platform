# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ────────────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production
LOG_LEVEL=INFO
SQL_ECHO=false

# ────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@db-host:5432/console_sensei
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# ────────────────────────────────────────────────────────────────────────────
# AWS CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_ACCOUNT_ID=123456789012

# ────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS
# ────────────────────────────────────────────────────────────────────────────
# Claude (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-key
CLAUDE_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# OpenAI
OPENAI_API_KEY=your-openai-key
OPENAI_DEFAULT_MODEL=gpt-4-turbo

# ────────────────────────────────────────────────────────────────────────────
# CACHING (Redis)
# ────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis-host:6379/0
REDIS_CACHE_TTL=3600
REDIS_POOL_SIZE=10

# ────────────────────────────────────────────────────────────────────────────
# SECURITY
# ────────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30
ENCRYPTION_KEY=your-encryption-key-32-chars-long

# ────────────────────────────────────────────────────────────────────────────
# CORS & FRONTEND
# ────────────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://console-sensei.example.com
CORS_ORIGINS=https://console-sensei.example.com,https://app.console-sensei.example.com

# ────────────────────────────────────────────────────────────────────────────
# WEBSOCKET
# ────────────────────────────────────────────────────────────────────────────
WEBSOCKET_ENABLED=true
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# ────────────────────────────────────────────────────────────────────────────
# MONITORING & ALERTS
# ────────────────────────────────────────────────────────────────────────────
ENABLE_ANOMALY_DETECTION=true
ANOMALY_CHECK_INTERVAL_MINUTES=15
COST_SPIKE_THRESHOLD_PERCENT=20

# Email Alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_FROM=alerts@console-sensei.example.com

# Slack Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ALERTS_ENABLED=true

# ────────────────────────────────────────────────────────────────────────────
# GCP INTEGRATION
# ────────────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project
GCP_CREDENTIALS_PATH=/path/to/gcp-credentials.json

# ────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ────────────────────────────────────────────────────────────────────────────
FEATURE_REAL_TIME_MONITORING=true
FEATURE_MULTI_LLM=true
FEATURE_COST_FORECASTING=true
FEATURE_ANOMALY_DETECTION=true
FEATURE_SECURITY_HUB=true
FEATURE_CLOUDTRAIL=true
